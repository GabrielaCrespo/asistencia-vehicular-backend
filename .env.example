# ARCHIVO .env DE EJEMPLO (LOCAL - NO COMMITS A GIT)
# 
# Este archivo NO debe ser commiteado a Git por seguridad
# Pero lo puedes usar localmente para desarrollo
# 
# Para Render, configurar variables en Dashboard → Environment

# BASE DE DATOS
DB_HOST=localhost
DB_PORT=5432
DB_NAME=asistencia_vehicular
DB_USER=admin
DB_PASS=miPassword123

# AUTENTICACIÓN
SECRET_KEY=tu-clave-jwt-super-segura-cambiar-en-produccion-12345

# FRONTEND (para CORS)
FRONTEND_URL=http://localhost:4200

# EN PRODUCCIÓN (RENDER):
# Reemplaza arriba con valores de Render Dashboard:
# 
# DB_HOST=dpg-xxxxxxxxxxxx.render-backends.com
# DB_PORT=5432
# DB_NAME=asistencia_vehicular_xxx
# DB_USER=admin
# DB_PASS=tuContraseñaRealDeRender
# SECRET_KEY=tu-clave-jwt-para-render
# FRONTEND_URL=https://asistencia-vehicular-frontend.onrender.com
