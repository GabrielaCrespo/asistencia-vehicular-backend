# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees .env ni .env.local — están en .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Base de Datos ────────────────────────────────────────────────────────────
DB_HOST=tu_host_de_postgresql
DB_PORT=5432
DB_NAME=nombre_de_la_base_de_datos
DB_USER=usuario_de_bd
DB_PASS=password_de_bd

# ─── JWT ──────────────────────────────────────────────────────────────────────
SECRET_KEY=genera_una_clave_aleatoria_de_al_menos_32_caracteres
ALGORITHM=HS256

# ─── CORS — URL del frontend ──────────────────────────────────────────────────
# Producción:  https://tu-frontend.onrender.com
# Local:       http://localhost:4200  (esto va en .env.local, no aquí)
FRONTEND_URL=https://tu-frontend.onrender.com

# ─── Cloudinary (imágenes de incidentes) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=tu_gemini_api_key